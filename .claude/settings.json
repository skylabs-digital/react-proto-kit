{
  "permissions": {
    "allow": [
      "Bash(yarn install:*)",
      "Bash(yarn dev:*)",
      "Bash(yarn build:*)",
      "Bash(yarn preview:*)",
      "Bash(yarn test:*)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/qa-command-guard.sh"
          }
        ]
      }
    ]
  }
}
